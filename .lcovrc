# ==============================================================================
# LCOV Configuration for Fenrir Chess Engine
# ==============================================================================
# This configuration ensures compatibility between gcov 15.x and lcov 2.x
#
# Key settings:
# - checksum: Disabled due to format changes in gcov 15.x
# - geninfo_unexecuted_blocks: Handle unexecuted blocks properly
# ==============================================================================

# Disable checksum validation (gcov 15.x format incompatibility)
checksum = 0

# Handle unexecuted blocks on non-branch lines
geninfo_unexecuted_blocks = 0
